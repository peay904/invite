# Copy this file to .env and fill in your values before running docker compose.

# Full URL where this invite page is hosted (used to generate invite links)
INVITE_BASE_URL=https://invite.example.com

# Base URL of your Jellyfin server (used for API calls — no trailing slash)
JELLYFIN_SERVER_URL=https://jelly.example.com

# Admin API key from Jellyfin Dashboard → API Keys
JELLYFIN_API_KEY=your_api_key_here

# Full URL of your Jellyfin server (shown to users in the getting-started tips)
JELLYFIN_URL=https://jelly.example.com

# Full URL of your main site (shown in tips for browsing/adding content)
SITE_URL=https://example.com

# Domain served by Caddy (must match INVITE_BASE_URL hostname)
CADDY_DOMAIN=invite.example.com
